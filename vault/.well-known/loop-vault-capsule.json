{
  "contract": "loopxxi.vault.capsule",
  "contractVersion": "1.0.0",
  "supported": true,
  "producer": true,
  "consumer": false,
  "appId": "loopxxi.foundry-collector",
  "appType": "agent_outcome",
  "zero_knowledge": true,
  "server_sees": "nothing_local_only",
  "producer_notes": "Foundry Collector runs entirely on the owner's machine and never transmits data externally. Sealing to a Vault capsule happens client-side; LoopXXI Vault infrastructure only ever receives the opaque envelope if the owner chooses to sync or list it.",
  "envelope_schema_url": "https://loopxxi.com/schemas/vault-capsule-v1.json",
  "source_capsule_schema_url": "https://loopxxi.com/schemas/agent-outcome-capsule-v0.1.json",
  "attestation": { "modes": ["poc_local", "production_server"] },
  "buyer_key_wrap": "ecdh-p256-aesgcm",
  "vault_ingest_url": "https://vault.loopxxi.com",
  "exporter": {
    "command": "node vault/foundry-vault-export.mjs -i <aoc-capsule.json> -o <vault-capsule.json>",
    "input": "a signed Agent Outcome Capsule (AOC) v0.1.0",
    "output": "a loopxxi.vault.capsule v1.0.0 envelope"
  },
  "contact": "business@loopxxi.com"
}
